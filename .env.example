# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentsforstocks
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentsforstocks

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenViking — knowledge/memory layer for agents
OPENVIKING_URL=http://localhost:1933
OPENVIKING_API_KEY=                     # leave blank unless you set root_api_key in ov.conf
OPENVIKING_ENABLED=true                 # set false to disable in tests

# External financial data (optional — yfinance works without a key)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Brave Search (MCP — for Claude Code sessions, not runtime)
BRAVE_API_KEY=your_brave_api_key_here
